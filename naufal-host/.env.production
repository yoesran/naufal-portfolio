# Production build env — loaded automatically by `vite build` (mode=production).
# VITE_* values are embedded in the client bundle, so they are public by design
# and safe to commit (no secrets here).

# The deployed Svelte remote's origin (Cloudflare Pages). The federation entry
# becomes ${VITE_LAB_URL}/remoteEntry.js at runtime.
VITE_LAB_URL=https://naufal-lab.pages.dev

# The deployed PartyKit server — HOSTNAME ONLY, no protocol (the client upgrades
# to wss:// automatically on an HTTPS page). Replace <username> with the value
# `npx partykit deploy` prints, e.g. naufal-party.janedoe.partykit.dev
VITE_PARTY_HOST=naufal-party.yoesran.partykit.dev
