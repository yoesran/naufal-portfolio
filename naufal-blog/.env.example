# Copy to `.env.production` (gitignored) before building, or set in the build env.
# NEXT_PUBLIC_* values are inlined into the static export, so they are public by
# design — no secrets here.

# Cloudflare Web Analytics beacon token. From the CF dashboard → Web Analytics →
# your site. Leave unset to ship no beacon (e.g. on a fork, or local dev).
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Canonical origin (no trailing slash) — feeds metadata, sitemap, robots, and
# hreflang. Flip to https://blog.naufal.dev when the custom domain goes live.
# Unset defaults to https://naufal-blog.pages.dev.
NEXT_PUBLIC_SITE_URL=

# The sibling portfolio's origin — linked from the home page. Flip to
# https://naufal.dev when the custom domain goes live. Unset defaults to
# https://naufal-host.pages.dev.
NEXT_PUBLIC_HOST_URL=
